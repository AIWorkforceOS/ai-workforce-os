# =============================================================================
# AI Workforce OS — Environment Variables Example
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (get from Supabase project settings) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (future) ---
# AUTH_SECRET=

# --- AI Provider (future) ---
# ANTHROPIC_API_KEY=

# --- Evolution API (WhatsApp) ---
# One global instance used by all units (unit gets its own instance auto-named as "unit-{slug}")
EVOLUTION_API_URL=https://evolution.yourserver.com
EVOLUTION_API_KEY=your_global_api_key

# --- Meta Lead Ads webhook ---
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
META_PAGE_ACCESS_TOKEN=your_meta_page_access_token

# --- Generic lead intake ---
INTAKE_SECRET=your_random_intake_secret
