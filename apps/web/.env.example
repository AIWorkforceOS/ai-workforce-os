# =============================================================================
# AI Workforce OS — Web App Environment Variables Example
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (get from Supabase project settings) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (future) ---
# AUTH_SECRET=

# --- AI Provider (future) ---
# ANTHROPIC_API_KEY=

# --- OpenAI (Agente SDR) ---
OPENAI_API_KEY=sk-...

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=https://sua-instancia-evolution.com
EVOLUTION_API_KEY=sua_api_key_aqui

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=sua_api_key_aqui

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM_DOMAIN=smarterestagios.com.br
