# =============================================================================
# AI Workforce OS — Web App Environment Variables Example
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase (get from Supabase project settings) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (Agente SDR + chat Kai da landing page) ---
OPENAI_API_KEY=sk-...

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=https://sua-instancia-evolution.com
EVOLUTION_API_KEY=sua_api_key_aqui

# --- Twilio (SMS — canal alternativo ao WhatsApp, ex.: unidades nos EUA) ---
# Cada empresa cliente normalmente tem sua própria conta Twilio (registro
# A2P 10DLC é por empresa) — estes env vars são só um fallback global;
# o normal é preencher units.twilio_account_sid/auth_token/phone_number
# via /dashboard/messaging/connect.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=sua_api_key_aqui

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM_DOMAIN=smarterestagios.com.br

# --- Webhook de intake de leads ---
# Token global (opcional — cada unidade tem o próprio token em units.intake_token)
INTAKE_SECRET=

# --- Cron de follow-up automático (Vercel Cron) ---
# Obrigatório em produção: a Vercel envia este valor como Bearer token
CRON_SECRET=
# Dias sem resposta antes do follow-up automático (padrão: 3)
FOLLOW_UP_AFTER_DAYS=3
# Máximo de follow-ups automáticos por lead (padrão: 2)
FOLLOW_UP_MAX=2
# Teto de envios por unidade por execução do cron (padrão: 10)
FOLLOW_UP_MAX_PER_UNIT=10
